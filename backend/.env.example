# Database Configuration
MONGO_URL=mongodb://localhost:27017/craftify_templates
DB_NAME=craftify_templates

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_EXPIRE=30d

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FROM_EMAIL=noreply@craftify.com
FROM_NAME=Craftify Templates

# Frontend URL (for CORS, email links, and Stripe redirect URLs)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Stripe — payments & subscriptions (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring plan price id (Stripe Dashboard → Products → Price → API ID)
STRIPE_SUBSCRIPTION_PRICE_ID=

# Dev only: allow POST /api/orders while Stripe keys exist (bypasses secure checkout). Never enable in production.
# DEV_ALLOW_DIRECT_ORDERS=true

# Optional: Custom SMTP Configuration
# SMTP_HOST=your-smtp-server.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
